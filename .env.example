# Consumed by docker-compose.yml for the mysql service's environment block.
# Keep these in sync with backend/.env.example's DB_* values.
DB_DATABASE=sinodtech
DB_USERNAME=sinodtech
DB_PASSWORD=secret

# Host-side ports docker-compose.yml maps its services to.
FRONTEND_PORT=8001
BACKEND_PORT=8002
PHPMYADMIN_PORT=8003
